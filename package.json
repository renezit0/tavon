{
  "name": "restaurant-qr-suite",
  "version": "0.1.7",
  "private": true,
  "description": "Sistema multi-restaurante para pedidos por QR Code, cozinha, caixa e administracao.",
  "workspaces": [
    "apps/api",
    "apps/desktop",
    "apps/web",
    "apps/server-manager",
    "packages/shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/web",
    "mac:build": "npm run build",
    "mac:admin": "APP_MODULE=admin electron apps/desktop/",
    "mac:cardapio": "APP_MODULE=cardapio electron apps/desktop/",
    "mac:garcom": "APP_MODULE=garcom electron apps/desktop/",
    "mac:cozinha": "APP_MODULE=cozinha electron apps/desktop/",
    "mac:caixa": "APP_MODULE=caixa electron apps/desktop/",
    "mac:server": "electron apps/server-manager/",
    "desktop:dist:win": "npm run dist:win -w apps/desktop",
    "desktop:dist:win:all": "npm run dist:win:all -w apps/desktop",
    "desktop:dist:win:admin": "npm run dist:win:admin -w apps/desktop",
    "desktop:dist:win:cardapio": "npm run dist:win:cardapio -w apps/desktop",
    "desktop:dist:win:garcom": "npm run dist:win:garcom -w apps/desktop",
    "desktop:dist:win:cozinha": "npm run dist:win:cozinha -w apps/desktop",
    "desktop:dist:win:caixa": "npm run dist:win:caixa -w apps/desktop",
    "desktop:dist:mac": "npm run dist:mac -w apps/desktop",
    "desktop:dist:mac:all": "npm run dist:mac:all -w apps/desktop",
    "desktop:dist:mac:admin": "npm run dist:mac:admin -w apps/desktop",
    "desktop:dist:mac:cardapio": "npm run dist:mac:cardapio -w apps/desktop",
    "desktop:dist:mac:garcom": "npm run dist:mac:garcom -w apps/desktop",
    "desktop:dist:mac:cozinha": "npm run dist:mac:cozinha -w apps/desktop",
    "desktop:dist:mac:caixa": "npm run dist:mac:caixa -w apps/desktop",
    "desktop:publish:win:all": "npm run publish:win:all -w apps/desktop",
    "desktop:publish:win:admin": "npm run publish:win:admin -w apps/desktop",
    "desktop:publish:win:cardapio": "npm run publish:win:cardapio -w apps/desktop",
    "desktop:publish:win:garcom": "npm run publish:win:garcom -w apps/desktop",
    "desktop:publish:win:cozinha": "npm run publish:win:cozinha -w apps/desktop",
    "desktop:publish:win:caixa": "npm run publish:win:caixa -w apps/desktop",
    "server-manager:dist:win": "npm run dist:win -w apps/server-manager",
    "server-manager:publish:win": "npm run publish:win -w apps/server-manager",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w apps/api && npm run typecheck -w apps/web",
    "lint": "npm run lint -w apps/web",
    "preview": "npm run preview -w apps/web",
    "server-manager:dist:mac": "npm run dist:mac -w apps/server-manager"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
