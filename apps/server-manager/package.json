{
  "name": "@restaurant/server-manager",
  "version": "0.1.22",
  "private": true,
  "description": "Tavon Server Manager — gerencia o servidor backend da suite Tavon.",
  "author": "Tavon",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "WEB_URL=http://localhost:5181 electron .",
    "dev:ui": "vite --port 5181",
    "build": "cd ../.. && npm run build -w packages/shared && npm run build -w apps/api && cd apps/server-manager && tsc -p tsconfig.json && vite build && node scripts/prepare-runtime.cjs",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "publish:win": "npm run build && electron-builder --win nsis --x64 --publish always",
    "dist:mac": "npm run build && electron-builder --mac dmg --config.directories.output=../../release/mac --config.artifactName=Tavon-Server-\\${version}.dmg"
  },
  "build": {
    "appId": "com.tavon.restaurant.server",
    "productName": "Tavon Server",
    "artifactName": "Tavon-Server-Setup-${version}.exe",
    "publish": {
      "provider": "github",
      "owner": "renezit0",
      "repo": "tavon",
      "tagNamePrefix": "server-v",
      "releaseType": "release"
    },
    "directories": {
      "output": "../../release/windows"
    },
    "files": [
      "electron-main.cjs",
      "preload.cjs",
      "package.json",
      "build/**/*",
      "ui-dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../api/dist",
        "to": "api/dist"
      },
      {
        "from": ".server-runtime/node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../packages/shared",
        "to": "node_modules/@restaurant/shared",
        "filter": [
          "dist/**/*",
          "package.json"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "extraMetadata": {
      "updaterCacheDirName": "tavon-server-updater",
      "name": "tavon-server"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "35.0.0",
    "electron-builder": "26.8.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.10"
  }
}
